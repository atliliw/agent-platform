# ========================================
# Agent Platform 环境变量示例
# ========================================
# 使用方法：复制本文件为 .env 并填入真实值
#   cp .env.example .env
# .env 已被 .gitignore 忽略，切勿提交真实密钥

# LLM API Key（必填）- 阿里云 DashScope (通义千问)
# 获取地址：https://dashscope.console.aliyun.com/
OPENAI_API_KEY=your-dashscope-api-key-here

# 以下为可选项，config 加载器会用环境变量覆盖 config.yaml 中的同名配置
# LLM_PROVIDER=dashscope
# LLM_MODEL=qwen3.7-max-2026-06-08
# QDRANT_URL=http://qdrant:6333
# MONGODB_URL=mongodb://mongo:27017
# REDIS_URL=redis://redis:6379
